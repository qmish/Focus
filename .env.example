# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=focus

# Keycloak bootstrap
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=company
KEYCLOAK_CLIENT_ID=messenger-api
KEYCLOAK_CLIENT_SECRET=secret

# Jitsi integration (API)
JITSI_BASE_URL=https://meet.company.com
JITSI_APP_ID=jitsi
JITSI_APP_SECRET=focus-jitsi-secret

# API session token secret (must differ from Jitsi secret)
SESSION_SECRET=focus-session-secret

# Frontend runtime envs (browser-side)
FRONTEND_VITE_API_URL=http://localhost:8080
FRONTEND_VITE_KEYCLOAK_URL=http://localhost:8180
FRONTEND_VITE_KEYCLOAK_CLIENT_ID=messenger-frontend

# Frontend-admin runtime envs (browser-side)
ADMIN_VITE_API_URL=http://localhost:8080
ADMIN_VITE_KEYCLOAK_URL=http://localhost:8180
ADMIN_VITE_KEYCLOAK_CLIENT_ID=messenger-admin
