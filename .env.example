# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=focus

# Keycloak bootstrap
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=company
KEYCLOAK_CLIENT_ID=messenger-api
KEYCLOAK_CLIENT_SECRET=secret
# JSON mapping: group -> roles/scopes for Focus API
KEYCLOAK_GROUP_POLICY_MAPPING=[]

# Jitsi integration (API)
JITSI_BASE_URL=https://meet.company.com
JITSI_APP_ID=jitsi
JITSI_APP_SECRET=focus-jitsi-secret

# API session token secret (must differ from Jitsi secret)
SESSION_SECRET=focus-session-secret
# Session token lifetime (Go duration format, min 15m in non-dev)
AUTH_SESSION_TOKEN_LIFETIME=24h
# Previous session secrets accepted for validation during rotation (comma-separated)
AUTH_SESSION_VALIDATION_SECRETS=
# WebSocket origin allowlist and strict room authorization policy
WS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173,http://localhost:5174
WS_STRICT_ROOM_ACCESS=false
# Required audience for API session JWT validation
AUTH_REQUIRED_AUDIENCE=focus-frontend
# Service client audience/scope policy (comma-separated)
AUTH_SERVICE_AUDIENCES=focus-service
AUTH_SERVICE_SCOPES=focus.service

# Окно редактирования сообщений в часах (0 — без ограничения, default 24)
MESSAGE_EDIT_WINDOW_HOURS=24

# Push-уведомления (Web Push). Сгенерировать ключи можно через:
#   cd API_Go && go run ./cmd/vapidgen
PUSH_ENABLED=false
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@focus.local
PUSH_WEBPUSH_TTL=24h
PUSH_WEBPUSH_TIMEOUT=10s
PUSH_FCM_ENABLED=false
PUSH_APNS_ENABLED=false

# Frontend runtime envs (browser-side)
FRONTEND_VITE_API_URL=http://localhost:8080
FRONTEND_VITE_KEYCLOAK_URL=http://localhost:8180
FRONTEND_VITE_KEYCLOAK_CLIENT_ID=messenger-frontend
FRONTEND_VITE_JITSI_DOMAIN=meet.company.com

# Frontend-admin runtime envs (browser-side)
ADMIN_VITE_API_URL=http://localhost:8080
ADMIN_VITE_KEYCLOAK_URL=http://localhost:8180
ADMIN_VITE_KEYCLOAK_CLIENT_ID=messenger-admin
