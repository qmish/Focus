{
  "name": "focus-e2e-tests",
  "version": "1.0.0",
  "description": "E2E tests for Focus Messenger",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
