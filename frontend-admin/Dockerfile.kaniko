FROM node:20-alpine AS builder

WORKDIR /app

COPY package*.json ./
RUN npm ci --no-audit --no-fund --force

COPY . .
RUN chmod +x node_modules/.bin/* node_modules/@esbuild/*/bin/* 2>/dev/null; node node_modules/vite/bin/vite.js build

FROM nginx:1.27-alpine

COPY --from=builder /app/dist /usr/share/nginx/html

RUN sed -i 's/listen\s*\[::\]:80/# listen [::]:80/' /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
